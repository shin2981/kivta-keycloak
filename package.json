{
  "name": "kivta-keycloak-theme",
  "version": "0.0.0",
  "description": "Keycloakify theme for Kivta - login, register, password, email",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "keycloak:dev": "vite",
    "build": "tsc -b && vite build",
    "keycloak:build": "npm run build && keycloakify build"
  },
  "dependencies": {
    "keycloakify": "^11.15.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwindcss-animate": "^1.0.7",
    "tailwind-merge": "^2.6.0",
    "clsx": "^2.1.1",
    "class-variance-authority": "^0.7.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "lucide-react": "^0.378.0",
    "react-hook-form": "^7.71.1",
    "@hookform/resolvers": "^5.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "18.3.23",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3",
    "vite": "^5.0.8"
